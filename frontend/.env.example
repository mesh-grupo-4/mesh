# Modo LAN (recomendado en iPhone/Android con Expo Go en la misma WiFi):
# NO definir EXPO_PUBLIC_API_URL — se auto-detecta desde Metro.
#
# Si ves timeout en iOS, poné la IP local de tu PC:
# EXPO_PUBLIC_API_URL=http://192.168.1.XX:3000
# (Windows: ipconfig → IPv4. Reiniciá Expo tras cambiar .env)
#
# Modo túnel (UTN / AP isolation / expo start --tunnel):
# EXPO_PUBLIC_API_URL=https://xxxx.ngrok-free.app

# Emulador Android (solo si auto-detect falla):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Supabase Realtime (Broadcast TRIP_STARTED al iniciar viaje)
# URL del proyecto (Settings → API Keys → Project URL). NO usar /rest/v1
# EXPO_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
