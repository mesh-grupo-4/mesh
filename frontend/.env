# Modo LAN (recomendado): NO definir EXPO_PUBLIC_API_URL — se auto-detecta desde Metro.
#
# Modo túnel (UTN / AP isolation): descomentá y poné la URL HTTPS de ngrok:
# EXPO_PUBLIC_API_URL=https://xxxx.ngrok-free.app
#
# Emulador Android (solo si auto-detect falla):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
