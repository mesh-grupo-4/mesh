generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RolMiembro {
  lider
  participante
}

enum TipoActividad {
  moto
  bici
  running
  trekking
}

enum EstadoViaje {
  planificado
  en_curso
  finalizado
}

enum CategoriaParada {
  kiosco
  combustible
  descanso
  gastronomia
  punto_control
  sanitario
  otro
}

enum GpsSource {
  live
  offline_sync
}

enum EstadoInvitacionGrupo {
  pendiente
  aceptada
  rechazada
}

enum EstadoAmistad {
  pendiente
  aceptada
  rechazada
}

enum EstadoViajeIntegrante {
  pendiente
  confirmado
  rechazado
}

enum OrigenViajeIntegrante {
  creador
  qr
  link
  grupo
  amigo
}

model Usuario {
  id                  String         @id @default(uuid()) @db.Uuid
  firebase_uid        String         @unique @map("firebase_uid")
  email               String         @unique
  nombre              String
  apellido            String?
  telefono            String?
  actividad_preferida TipoActividad? @map("actividad_preferida")
  push_token          String?        @map("push_token")

  grupos_liderados       Grupo[]            @relation("GrupoLider")
  membresias             GrupoMiembro[]
  viajes_creados         Viaje[]            @relation("ViajeCreador")
  participaciones_viaje  ViajeIntegrante[]
  registros_gps          RegistroGPS[]
  ubicacion_viva         UbicacionViva?
  invitaciones_recibidas GrupoInvitacion[]  @relation("InvitacionesRecibidas")
  invitaciones_enviadas  GrupoInvitacion[]  @relation("InvitacionesEnviadas")
  amistades_solicitadas  Amistad[]          @relation("AmistadSolicitante")
  amistades_recibidas    Amistad[]          @relation("AmistadDestinatario")

  @@map("usuario")
}

model Grupo {
  id             String   @id @default(uuid()) @db.Uuid
  nombre         String
  fecha_creacion DateTime @default(now()) @map("fecha_creacion")
  lider_id       String   @map("lider_id") @db.Uuid

  lider                Usuario           @relation("GrupoLider", fields: [lider_id], references: [id], onDelete: Restrict)
  miembros             GrupoMiembro[]
  viajes               ViajeGrupo[]
  invitaciones_destino GrupoInvitacion[] @relation("InvitacionesDestino")
  invitaciones_origen  GrupoInvitacion[] @relation("InvitacionesOrigen")

  @@map("grupo")
}

model GrupoMiembro {
  grupo_id    String   @map("grupo_id") @db.Uuid
  usuario_id  String   @map("usuario_id") @db.Uuid
  rol         RolMiembro
  fecha_union DateTime @default(now()) @map("fecha_union")

  grupo   Grupo   @relation(fields: [grupo_id], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@id([grupo_id, usuario_id])
  @@map("grupo_miembro")
}

model GrupoInvitacion {
  id              String                @id @default(uuid()) @db.Uuid
  grupo_id        String                @map("grupo_id") @db.Uuid
  usuario_id      String                @map("usuario_id") @db.Uuid
  invitado_por_id String                @map("invitado_por_id") @db.Uuid
  grupo_origen_id String?               @map("grupo_origen_id") @db.Uuid
  estado          EstadoInvitacionGrupo @default(pendiente)
  created_at      DateTime              @default(now()) @map("created_at")

  grupo        Grupo   @relation("InvitacionesDestino", fields: [grupo_id], references: [id], onDelete: Cascade)
  grupo_origen Grupo?  @relation("InvitacionesOrigen", fields: [grupo_origen_id], references: [id], onDelete: Cascade)
  usuario      Usuario @relation("InvitacionesRecibidas", fields: [usuario_id], references: [id], onDelete: Cascade)
  invitado_por Usuario @relation("InvitacionesEnviadas", fields: [invitado_por_id], references: [id], onDelete: Cascade)

  @@unique([grupo_id, usuario_id])
  @@index([usuario_id, estado])
  @@map("grupo_invitacion")
}

model Amistad {
  id              String        @id @default(uuid()) @db.Uuid
  solicitante_id  String        @map("solicitante_id") @db.Uuid
  destinatario_id String        @map("destinatario_id") @db.Uuid
  estado          EstadoAmistad @default(pendiente)
  created_at      DateTime      @default(now()) @map("created_at")

  solicitante  Usuario @relation("AmistadSolicitante", fields: [solicitante_id], references: [id], onDelete: Cascade)
  destinatario Usuario @relation("AmistadDestinatario", fields: [destinatario_id], references: [id], onDelete: Cascade)

  @@unique([solicitante_id, destinatario_id])
  @@index([destinatario_id, estado])
  @@map("amistad")
}

model Viaje {
  id                 String      @id @default(uuid()) @db.Uuid
  creador_id         String      @map("creador_id") @db.Uuid
  nombre             String?
  es_grupal          Boolean     @map("es_grupal")
  tipo_actividad            TipoActividad @map("tipo_actividad")
  velocidad_esperada        Float         @map("velocidad_esperada")
  distancia_max_separacion  Int           @map("distancia_max_separacion")
  estado                    EstadoViaje   @default(planificado)
  fecha_programada DateTime    @map("fecha_programada")
  fecha_inicio_real  DateTime?   @map("fecha_inicio_real")
  fecha_fin_real     DateTime?   @map("fecha_fin_real")
  created_at         DateTime    @default(now()) @map("created_at")

  creador     Usuario           @relation("ViajeCreador", fields: [creador_id], references: [id], onDelete: Restrict)
  integrantes ViajeIntegrante[]
  grupos      ViajeGrupo[]

  ruta    Ruta?
  resumen ResumenViaje?
  registros_gps RegistroGPS[]
  ubicaciones_vivas UbicacionViva[]

  @@index([creador_id])
  @@map("viaje")
}

model UbicacionViva {
  usuario_id  String   @id @map("usuario_id") @db.Uuid
  viaje_id    String   @map("viaje_id") @db.Uuid
  lat         Float
  lng         Float
  precision_m Float?   @map("precision_m")
  updated_at  DateTime @updatedAt @map("updated_at")

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  viaje   Viaje   @relation(fields: [viaje_id], references: [id], onDelete: Cascade)

  @@index([viaje_id])
  @@map("ubicacion_viva")
}

model ViajeGrupo {
  viaje_id   String   @map("viaje_id") @db.Uuid
  grupo_id   String   @map("grupo_id") @db.Uuid
  created_at DateTime @default(now()) @map("created_at")

  viaje Viaje @relation(fields: [viaje_id], references: [id], onDelete: Cascade)
  grupo Grupo @relation(fields: [grupo_id], references: [id], onDelete: Cascade)

  @@id([viaje_id, grupo_id])
  @@index([grupo_id])
  @@map("viaje_grupo")
}

model ViajeIntegrante {
  viaje_id   String                @map("viaje_id") @db.Uuid
  usuario_id String                @map("usuario_id") @db.Uuid
  estado     EstadoViajeIntegrante
  origen     OrigenViajeIntegrante
  created_at DateTime              @default(now()) @map("created_at")

  viaje   Viaje   @relation(fields: [viaje_id], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@id([viaje_id, usuario_id])
  @@index([usuario_id, estado])
  @@map("viaje_integrante")
}

model RegistroGPS {
  id          String    @id @default(uuid()) @db.Uuid
  viaje_id    String    @map("viaje_id") @db.Uuid
  usuario_id  String    @map("usuario_id") @db.Uuid
  lat         Float
  lng         Float
  precision_m Float?    @map("precision_m")
  timestamp   DateTime
  source      GpsSource @default(live)
  created_at  DateTime  @default(now()) @map("created_at")

  viaje   Viaje   @relation(fields: [viaje_id], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([viaje_id, timestamp])
  @@index([usuario_id, timestamp])
  @@map("registro_gps")
}

model Ruta {
  id                   String  @id @default(uuid()) @db.Uuid
  viaje_id             String  @unique @map("viaje_id") @db.Uuid
  origen_lat           Float   @map("origen_lat")
  origen_lng           Float   @map("origen_lng")
  origen_nombre        String? @map("origen_nombre")
  destino_lat          Float   @map("destino_lat")
  destino_lng          Float   @map("destino_lng")
  destino_nombre       String? @map("destino_nombre")
  linestring_geojson   Json    @map("linestring_geojson")
  distancia_planeada_m Float?  @map("distancia_planeada_m")
  tiempo_estimado_seg  Int?    @map("tiempo_estimado_seg")

  viaje               Viaje               @relation(fields: [viaje_id], references: [id], onDelete: Cascade)
  paradas_intermedias ParadaIntermedia[]

  @@map("ruta")
}

model ParadaIntermedia {
  id         String          @id @default(uuid()) @db.Uuid
  ruta_id    String          @map("ruta_id") @db.Uuid
  orden      Int
  lat        Float
  lng        Float
  nombre     String?
  categoria  CategoriaParada @default(otro)

  ruta Ruta @relation(fields: [ruta_id], references: [id], onDelete: Cascade)

  @@index([ruta_id, orden])
  @@map("parada_intermedia")
}

model ResumenViaje {
  id                   String   @id @default(uuid()) @db.Uuid
  viaje_id             String   @unique @map("viaje_id") @db.Uuid
  duracion_segundos    Int?     @map("duracion_segundos")
  distancia_planeada_m Float?   @map("distancia_planeada_m")
  distancia_real_m     Float?   @map("distancia_real_m")
  cantidad_paradas     Int      @default(0) @map("cantidad_paradas")
  generado_en          DateTime @default(now()) @map("generado_en")

  viaje Viaje @relation(fields: [viaje_id], references: [id], onDelete: Cascade)

  @@map("resumen_viaje")
}
